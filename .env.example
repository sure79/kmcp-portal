# ==============================
# KMCP 연구소 업무포털 환경변수
# ==============================
# 이 파일을 복사해서 .env 파일을 만들고 실제 값을 입력하세요
# cp .env.example .env

# 서버
NODE_ENV=production
PORT=3000

# 세션 보안 (반드시 긴 랜덤 문자열로 변경!)
# 생성 방법: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=여기에_64자_이상의_랜덤_문자열_입력

# Turso 데이터베이스 (https://turso.tech)
TURSO_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Google AI Studio API 키 (https://aistudio.google.com/app/apikey)
# 회의 녹음 자동 분석 기능에 사용
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
